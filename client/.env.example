# Базовый URL API (без завершающего слэша).
# Соответствует серверу из openapi.yaml: https://api.studio.example.com/v1
EXPO_PUBLIC_API_BASE_URL=https://api.studio.example.com/v1

# Использовать встроенный mock (фикстуры из контракта) вместо реальных запросов.
# Удобно для локальной разработки и тестов без бэкенда: "true" | "false"
EXPO_PUBLIC_USE_MOCK=true

# Таймаут сетевых запросов в миллисекундах (необязательно).
EXPO_PUBLIC_REQUEST_TIMEOUT_MS=15000
